# Set AUTH_REQUIRED=1 to enable email registration/login and optional X login.
AUTH_REQUIRED=1
# Leave X settings empty when only email login is needed.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8765/auth/callback
SESSION_SECRET=

# Optional comma-separated allowlists. Leave both empty to allow every X account.
ALLOWED_X_USER_IDS=
ALLOWED_X_USERNAMES=

# Use 1 with an HTTPS production URL.
COOKIE_SECURE=0
