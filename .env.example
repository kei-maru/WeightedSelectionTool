# Set AUTH_REQUIRED=1 only after registering the callback URL in the X Developer Console.
AUTH_REQUIRED=0
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8765/auth/callback
SESSION_SECRET=

# Optional comma-separated allowlists. Leave both empty to allow every X account.
ALLOWED_X_USER_IDS=
ALLOWED_X_USERNAMES=

# Use 1 with an HTTPS production URL.
COOKIE_SECURE=0
